# Crossmint client-side API key — find it at https://staging.crossmint.com/console/projects/apiKeys
NEXT_PUBLIC_CROSSMINT_CLIENT_API_KEY=

# Crossmint server-side API key with `wallets.create` scope — required for authorizing a server signer on the wallet
CROSSMINT_SERVER_SIDE_API_KEY=

# 64-char hex secret (or `xmsk1_<64-hex>`) used by the server signer. Stays server-side only.
CROSSMINT_SIGNER_SECRET=
